  "lostLocation": "教学楼A101",
  "lostTime": "2026-04-16 10:30:00",
  "description": "测试删除用失物",
  "imageUrl": "https://example.com/lost-delete.jpg",
  "contactInfo": "电话:{{userAPhone}}"
}

