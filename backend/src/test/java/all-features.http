### 使用说明
# 1. 先启动后端服务，再在 IDEA 里按顺序执行本文件。
# 2. 注册接口第一次执行会成功；如果账号已存在，再次执行可能提示已存在，可直接继续执行登录请求。
# 2.1 这份文件会在后面修改用户A密码：从 123456 改成 12345678。
# 2.2 如果你重复整份执行，请把下面的 userAPassword 改成数据库里的当前密码，或者换一组全新的账号重新测。
# 3. 管理员接口依赖一个已存在的管理员账号，请先把下面的 adminAccount / adminPassword 改成你数据库里的管理员账号。
# 4. 举报审核、置顶审核目前没有“查询列表”接口，所以 reportIdManual / topRequestIdManual 需要你先从数据库里看一下再填。

@baseUrl = http://localhost:8080

@userAUsername = api_user_a
@userAEmail = api_user_a@qq.com
@userAPhone = 13812345671
@userAPassword = 123456
@userANewPassword = 12345678

@userBUsername = api_user_b
@userBEmail = api_user_b@qq.com
@userBPhone = 13812345672
@userBPassword = 123456

@lostMainName = 测试失物_校园卡_A
@lostDeleteName = 测试失物_待删除_A
@lostAdminDeleteName = 测试失物_管理员删除_A

@foundMainName = 测试拾物_钥匙_B
@foundDeleteName = 测试拾物_待删除_B
@foundAdminDeleteName = 测试拾物_管理员删除_B

@adminAccount = admin
@adminPassword = 123456
@reportIdManual = 1
@topRequestIdManual = 1

### 1. 注册用户A
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "{{userAUsername}}",
  "email": "{{userAEmail}}",
  "phone": "{{userAPhone}}",
  "password": "{{userAPassword}}",
  "confirmPassword": "{{userAPassword}}"
}

### 2. 注册用户B
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "{{userBUsername}}",
  "email": "{{userBEmail}}",
  "phone": "{{userBPhone}}",
  "password": "{{userBPassword}}",
  "confirmPassword": "{{userBPassword}}"
}

### 3. 登录用户A
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "account": "{{userAUsername}}",
  "password": "{{userAPassword}}"
}

> {%
if (response.body && response.body.code === 200 && response.body.data) {
  client.global.set("userAToken", response.body.data.token);
  client.global.set("userAId", response.body.data.userId);
} else {
  client.log("用户A登录失败，未写入 token。响应: " + JSON.stringify(response.body));
}
%}

### 4. 登录用户B
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "account": "{{userBUsername}}",
  "password": "{{userBPassword}}"
}

> {%
if (response.body && response.body.code === 200 && response.body.data) {
  client.global.set("userBToken", response.body.data.token);
  client.global.set("userBId", response.body.data.userId);
} else {
  client.log("用户B登录失败，未写入 token。响应: " + JSON.stringify(response.body));
}
%}

### 5. 用户A查看个人信息
GET {{baseUrl}}/users/me
Authorization: Bearer {{userAToken}}

### 6. 用户A修改个人信息
PUT {{baseUrl}}/users/profile
Content-Type: application/json
Authorization: Bearer {{userAToken}}

{
  "nickname": "测试用户A",
  "avatarUrl": "https://example.com/avatar-a.png",
  "contactInfo": "微信 api_user_a",
  "phone": "{{userAPhone}}"
}

### 7. 用户A修改密码
PUT {{baseUrl}}/users/password
Content-Type: application/json
Authorization: Bearer {{userAToken}}

{
  "oldPassword": "{{userAPassword}}",
  "newPassword": "{{userANewPassword}}",
  "confirmPassword": "{{userANewPassword}}"
}

### 8. 用户A用新密码重新登录
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "account": "{{userAUsername}}",
  "password": "{{userANewPassword}}"
}

> {%
if (response.body && response.body.code === 200 && response.body.data) {
  client.global.set("userAToken", response.body.data.token);
  client.global.set("userAId", response.body.data.userId);
} else {
  client.log("用户A重新登录失败，未更新 token。响应: " + JSON.stringify(response.body));
}
%}

### 9. 用户A发布主失物
POST {{baseUrl}}/lost-items
Content-Type: application/json
Authorization: Bearer {{userAToken}}

{
  "itemName": "{{lostMainName}}",
  "lostLocation": "图书馆三楼",
  "lostTime": "2026-04-16 10:00:00",
  "description": "蓝色卡套，可能掉在自习区",
  "imageUrl": "https://example.com/lost-main.jpg",
  "contactInfo": "微信:api_user_a"
}

### 10. 用户A发布待删除失物
